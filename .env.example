# DealerAddendums Marketing OS — Environment Variables
# Copy to .env.local and fill in values. Never commit .env.local

# ── Core ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://dealeraddendums.com
ADMIN_PASSWORD=
DA_CRON_KEY=

# ── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Analytics ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Google Tag Manager (optional; tags inert until set) ──────────────────────
# GTM container id (GTM-XXXXXXX). The container owns GA4 + the Google Ads
# conversion; the signup form pushes a `sign_up` dataLayer event for it to route.
NEXT_PUBLIC_GTM_ID=

# ── Email ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=allan@dealeraddendums.com

# ── CRM ──────────────────────────────────────────────────────────────────────
HUBSPOT_API_KEY=
HUBSPOT_PORTAL_ID=23896347

# ── Social Scheduling ────────────────────────────────────────────────────────
BUFFER_API_KEY=
# Alternative: TYPEFULLY_API_KEY=

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── DA Platform Supabase (READ-ONLY) ─────────────────────────────────────────
# Used by the Reputation Manager to read active dealers for review-request
# campaigns. NEVER write to this database. Leave blank to disable dealer
# segments (manual email paste still works).
DA_PLATFORM_SUPABASE_URL=https://byouefbebqgffhtfdggu.supabase.co
DA_PLATFORM_SUPABASE_SERVICE_KEY=

# ── Google Business Profile API — pending access approval from Google ────────
# The Reputation Manager runs on STUBBED mock reviews until these are set.
# Leave blank until Google approves the API access request.
# Once approved: add credentials and set GBP_LOCATION_NAME to
# accounts/XXXXXXX/locations/XXXXXXX to switch the module to live Google data.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GBP_LOCATION_NAME=
